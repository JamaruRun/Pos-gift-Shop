# ====== Supabase ======
# คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจริงจาก Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# ใช้ฝั่ง server เท่านั้น (Route Handler / Server Action) ห้าม expose ขึ้น client
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# ร้านปัจจุบัน (single store MVP) — ดู seed ใน docs/schema.sql
NEXT_PUBLIC_STORE_ID=00000000-0000-0000-0000-000000000001

# ====== LINE Messaging API (worker ฝั่ง backend จะใช้ ไม่ใช่ใน MVP UI นี้) ======
# LINE_CHANNEL_ACCESS_TOKEN=
# LINE_OWNER_USER_ID=

# หมายเหตุ: ถ้ายังไม่ตั้งค่า Supabase แอปจะรันในโหมด MOCK (ข้อมูลตัวอย่าง) อัตโนมัติ
