# ใช้ฝั่ง server เท่านั้น (Route Handler / Server Action) ห้าม expose ขึ้น client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImtrbnR0dXppbmFta29xZXF6bHp6Iiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MjExNTU0NCwiZXhwIjoyMDk3NjkxNTQ0fQ.1EsIx1Ud5A8ehrzOUN0II0WmX-6YcwtIfDvYfqiwNTQ

# ร้านปัจจุบัน (single store MVP) — ดู seed ใน docs/schema.sql
NEXT_PUBLIC_STORE_ID=00000000-0000-0000-0000-000000000001

# ====== LINE Messaging API (worker ฝั่ง server เท่านั้น — ห้ามมี NEXT_PUBLIC_) ======
# จาก LINE Developers Console > Messaging API channel
LINE_CHANNEL_ACCESS_TOKEN=
# LINE userId ของเจ้าของร้าน (ปลายทาง push)
LINE_OWNER_USER_ID=
# จำนวน notification ต่อรอบ (ค่าเริ่มต้น 20)
# LINE_NOTIFY_BATCH_SIZE=20

# ====== Worker / Cron ======
# secret สำหรับยืนยันว่า /api/notifications/process ถูกเรียกโดย cron จริง
CRON_SECRET=

# หมายเหตุ:
# - ถ้ายังไม่ตั้งค่า Supabase แอปรันโหมด MOCK (ข้อมูลตัวอย่าง) อัตโนมัติ
# - ถ้ายังไม่ตั้งค่า LINE_* ในโหมด dev worker จะ log ข้อความแทนการยิงจริง (mock) แล้ว mark sent
